import java.util.*;

class Solution_gfg_12 {
    public List<Integer> find3Numbers(int[] arr) {
        int n = arr.length;
        if (n < 3) return new ArrayList<>();

        // smaller[i] will store the index of a number smaller than arr[i] on the left
        int[] smaller = new int[n];
        smaller[0] = -1; // No element to the left of the first element
        int minIdx = 0;
        for (int i = 1; i < n; i++) {
            if (arr[i] <= arr[minIdx]) {
                minIdx = i;
                smaller[i] = -1;
            } else {
                smaller[i] = minIdx;
            }
        }

        // greater[i] will store the index of a number greater than arr[i] on the right
        int[] greater = new int[n];
        greater[n - 1] = -1; // No element to the right of the last element
        int maxIdx = n - 1;
        for (int i = n - 2; i >= 0; i--) {
            if (arr[i] >= arr[maxIdx]) {
                maxIdx = i;
                greater[i] = -1;
            } else {
                greater[i] = maxIdx;
            }
        }

        // Now, find an index i such that both smaller[i] and greater[i] are not -1
        List<Integer> result = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            if (smaller[i] != -1 && greater[i] != -1) {
                result.add(arr[smaller[i]]);
                result.add(arr[i]);
                result.add(arr[greater[i]]);
                return result; // Return the first valid subsequence found
            }
        }

        return result; // Return empty list if no such subsequence exists
    }
}
